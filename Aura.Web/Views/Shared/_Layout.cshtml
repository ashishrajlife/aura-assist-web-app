<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>AURA – Astrology</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/aura.css" rel="stylesheet" />
</head>
<body class="aura-body">

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg aura-navbar">
        <div class="container">
            <a class="navbar-brand aura-brand" href="/">AURA ✨</a>
            <span class="aura-tagline">Astrology & Cosmic Guidance</span>
        </div>
    </nav>

    <!-- PAGE CONTENT -->
    <main class="container aura-content">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="aura-footer">
        <p>© @DateTime.Now.Year AURA • Crafted with Cosmic Precision</p>
    </footer>

</body>
</html>
